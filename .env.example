# ── PostgreSQL ──────────────────────────────
POSTGRES_USER=fee_user
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=fee_sys

# ── Redis ───────────────────────────────────
REDIS_PASSWORD=change_me_redis_password

# ── Application ─────────────────────────────
SECRET_KEY=change_me_64_char_random_secret_key_here_replace_before_production
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# ── First admin user (auto-created on startup) ──
FIRST_ADMIN_USERNAME=admin
FIRST_ADMIN_EMAIL=admin@example.com
FIRST_ADMIN_PASSWORD=change_me_admin_password

# ── Frontend ────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000

# ── Encryption key for webhook URLs (Fernet 32-byte base64) ──
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=change_me_generate_fernet_key_here
