# =============================================================
# 费用管理系统 环境变量配置示例
# 复制此文件为 .env 并填入真实值后启动
# cp .env.example .env
# =============================================================

# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_USER=fee_user
# 生产环境请使用强随机密码: openssl rand -base64 24
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=fee_sys

# ── Redis ───────────────────────────────────────────────────
# 生产环境请使用强随机密码: openssl rand -base64 20
REDIS_PASSWORD=change_me_redis_password

# ── Application ─────────────────────────────────────────────
# 生产环境必须替换: openssl rand -hex 32
SECRET_KEY=change_me_64_char_random_secret_key_here_replace_before_production
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# ── 初始管理员账号（仅首次启动时自动创建）──────────────────
FIRST_ADMIN_USERNAME=admin
FIRST_ADMIN_EMAIL=admin@example.com
# 生产环境请使用强密码（至少12位含大小写数字）
FIRST_ADMIN_PASSWORD=change_me_admin_password

# ── Webhook URL 加密密钥（Fernet 32字节 base64）────────────
# 生成命令: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# 警告: 一旦设置不可更改，否则已存储的 Webhook URL 将无法解密
ENCRYPTION_KEY=change_me_generate_fernet_key_here

# ── Local port bindings ──────────────────────────────────────
# 宿主机端口映射；服务器上如已有服务占用 3000/8000，可改为其他端口
WEB_PORT=3000
API_PORT=8000

# Optional Docker image registry prefix, useful when Docker Hub is slow/unavailable.
# Example: IMAGE_REGISTRY=docker.m.daocloud.io/library/
IMAGE_REGISTRY=

# Optional Python package index used during backend image builds.
# Example: PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
PIP_INDEX_URL=

# ── AI 费用监控 ─────────────────────────────────────────────
# 灰度期保持 true，仅管理员可查看和操作 AI 模块
AI_MONITOR_ADMIN_ONLY=true
# 系统签发的 DeepSeek Gateway Key 默认每分钟请求上限
AI_GATEWAY_DEFAULT_RATE_LIMIT=60
# DeepSeek OpenAI 兼容 API 地址；一般无需修改
DEEPSEEK_BASE_URL=https://api.deepseek.com
# 厂商请求超时秒数
AI_PROVIDER_TIMEOUT_SECONDS=120
